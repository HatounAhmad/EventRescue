@model List<EventRescue.Models.EventRequest>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<EventRescue.SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["AvailableRequests"];
    var currentProviderId = ViewBag.CurrentProviderId as string;

    // إحصائيات سريعة للهيرو
    var myOffersCount = Model.Count(r => r.ProviderOffers.Any(o => o.ProviderId == currentProviderId));
    var emergencyCount = Model.Count(r => r.EventDate <= DateTime.Now.AddHours(24));
}

<div class="container er-page mt-4 mb-5">

    @* ================== الهيرو ================== *@
    <section class="er-hero mb-4">
        <div class="er-hero-content">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="er-badge">
                        <i class="bi bi-broadcast"></i>
                        @Localizer["RadarBadge"]
                    </div>
                    <h1 class="er-title">@Localizer["RadarTitle"]</h1>
                    <p class="er-subtitle mb-0">
                        @Localizer["RadarHeroText"]
                    </p>
                </div>
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="row g-3 text-center">
                        <div class="col-4">
                            <div class="er-stat py-3">
                                <div class="er-stat-number text-primary">@Model.Count</div>
                                <div class="er-muted small">@Localizer["RadarStatAvailable"]</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="er-stat py-3">
                                <div class="er-stat-number text-info">@myOffersCount</div>
                                <div class="er-muted small">@Localizer["RadarStatMyOffers"]</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="er-stat py-3">
                                <div class="er-stat-number text-danger">@emergencyCount</div>
                                <div class="er-muted small">@Localizer["RadarStatUrgent"]</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ================== رسائل النجاح والخطأ ================== *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ================== حالة عدم وجود طلبات ================== *@
    @if (!Model.Any())
    {
        <div class="er-card er-card-body text-center py-5">
            <span class="er-soft-icon mb-3" style="width: 70px; height: 70px; font-size: 2rem;">
                <i class="bi bi-inbox"></i>
            </span>
            <h5 class="fw-bold">@Localizer["RadarNoRequestsTitle"]</h5>
            <p class="er-muted mb-0">@Localizer["RadarNoRequestsText"]</p>
        </div>
    }

    @* ================== بطاقات الطلبات ================== *@
    <div class="row g-4">
        @foreach (var request in Model)
        {
            var myOffer = request.ProviderOffers
                .FirstOrDefault(o => o.ProviderId == currentProviderId);

            var isEmergency = request.EventDate <= DateTime.Now.AddHours(24);

            <div class="col-xl-6">
                <div class="er-card h-100 overflow-hidden">

                    @if (!string.IsNullOrEmpty(request.ImagePath))
                    {
                        <img src="@request.ImagePath" alt="@Localizer["MyRequestsImageAlt"]"
                             style="width: 100%; height: 190px; object-fit: cover;" />
                    }

                    <div class="er-card-body">

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="er-soft-icon">
                                    <i class="@request.Category?.Icon"></i>
                                </span>
                                <strong>@request.Category?.Name</strong>
                            </div>
                            @if (isEmergency)
                            {
                                <span class="er-status er-status-canceled">
                                    <i class="bi bi-alarm-fill"></i> @Localizer["RadarEmergencyBadge"]
                                </span>
                            }
                            else
                            {
                                <span class="er-status er-status-pending">
                                    <i class="bi bi-hourglass-split"></i> @Localizer["RadarStatusOpen"]
                                </span>
                            }
                        </div>

                        <h5 class="fw-bold">@request.Title</h5>
                        <p class="er-muted">@request.Description</p>

                        <div class="d-flex flex-wrap gap-3 small er-muted mb-3">
                            <span><i class="bi bi-geo-alt-fill text-primary"></i> @request.Region?.Name — @request.Address</span>
                            <span><i class="bi bi-calendar-event text-primary"></i> @request.EventDate.ToString("yyyy/MM/dd — hh:mm tt")</span>
                            <span><i class="bi bi-people-fill text-primary"></i> @request.ProviderOffers.Count @Localizer["RadarOffersCount"]</span>
                        </div>

                        @if (myOffer != null)
                        {
                            @* عرضي المقدم + زر سحب العرض (عملية Delete) *@
                            <div class="alert alert-info rounded-4 py-2 mb-2">
                                <i class="bi bi-hourglass-split"></i>
                                @Localizer["RadarYouOffered"] <strong>@myOffer.Price @Localizer["DetailsRiyal"]</strong>
                                — @Localizer["RadarWaitingClient"]
                            </div>
                            <form asp-controller="Providers" asp-action="WithdrawOffer" method="post"
                                  onsubmit="return confirm('@Localizer["RadarConfirmWithdraw"]');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="offerId" value="@myOffer.Id" />
                                <button type="submit" class="btn btn-outline-danger er-btn w-100">
                                    <i class="bi bi-trash3"></i> @Localizer["RadarWithdrawOffer"]
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="Providers" asp-action="SendOffer" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventRequestId" value="@request.Id" />
                                <div class="input-group">
                                    <span class="input-group-text">@Localizer["DetailsRiyal"]</span>
                                    <input type="number" name="price" class="form-control"
                                           placeholder="@Localizer["RadarPricePlaceholder"]" min="1" max="100000" step="0.5" required />
                                    <button type="submit" class="btn btn-primary er-btn">
                                        <i class="bi bi-send-fill"></i> @Localizer["RadarSendOffer"]
                                    </button>
                                </div>
                            </form>
                        }

                    </div>
                </div>
            </div>
        }
    </div>

</div>
