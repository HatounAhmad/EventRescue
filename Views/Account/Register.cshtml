@model EventRescue.ViewModels.RegisterViewModel
@using EventRescue.Models
@using EventRescue.Models.Enums
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<EventRescue.SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["RegisterNewAccount"];

    var regions = ViewBag.Regions as List<Region>;
    var categories = ViewBag.Categories as List<Category>;

    var isEnglish = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en");

   var regionTranslations = new Dictionary<string, string>
{
    { "الرياض", "Riyadh" },
    { "جدة", "Jeddah" },
    { "الدمام", "Dammam" },
    { "مكة", "Makkah" },
    { "المدينة المنورة", "Madinah" }
};

    var categoryTranslations = new Dictionary<string, string>
{
    { "قهوجي أو قهوجية", "Coffee Server" },
    { "مقدمات ضيافة", "Hospitality Hostesses" },
    { "عاملة تنظيف", "Cleaning Worker" },
    { "فني إصلاح أثاث", "Furniture Repair Technician" },
    { "منسق ورد", "Flower Coordinator" },
    { "مصور مناسبات", "Event Photographer" },
    { "شيف منزلي", "Home Chef" },
    { "سائق توصيل", "Delivery Driver" },
    { "كراسي وطاولات", "Tables and Chairs" },
    { "كنب", "Sofas" },
    { "خيام", "Tents" },
    { "سخانات ومبردات", "Heaters and Coolers" }
};
}
<style>
    body {
        background:
            radial-gradient(circle at top right, rgba(147, 197, 253, 0.25), transparent 28%),
            radial-gradient(circle at bottom left, rgba(187, 247, 208, 0.22), transparent 30%),
            #f4f7fb;
    }

    .register-page {
        direction: rtl;
        color: #1f2937;
    }

    html[dir="ltr"] .register-page {
        direction: ltr;
    }

    .register-layout {
        display: grid;
        grid-template-columns: 390px 1fr;
        gap: 26px;
        align-items: stretch;
    }

    .brand-card,
    .form-card {
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid #dbe7f3;
        border-radius: 32px;
        box-shadow: 0 18px 45px rgba(71, 85, 105, 0.09);
        backdrop-filter: blur(10px);
    }

    .brand-card {
        padding: 30px;
        background:
            linear-gradient(135deg, #ffffff 0%, #eaf3ff 55%, #eefbf3 100%);
        position: relative;
        overflow: hidden;
    }

    .brand-card::after {
        content: "";
        position: absolute;
        width: 210px;
        height: 210px;
        border-radius: 50%;
        background: rgba(147, 197, 253, 0.28);
        left: -70px;
        bottom: -80px;
    }

    .brand-content {
        position: relative;
        z-index: 2;
    }

    .brand-icon {
        width: 78px;
        height: 78px;
        border-radius: 26px;
        background: linear-gradient(135deg, #93c5fd, #bbf7d0);
        color: #1e3a5f;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        margin-bottom: 22px;
        box-shadow: 0 16px 35px rgba(59, 130, 246, 0.14);
    }

    .brand-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #e0f2fe;
        color: #0369a1;
        border: 1px solid #bae6fd;
        border-radius: 999px;
        padding: 8px 15px;
        font-weight: 800;
        margin-bottom: 18px;
    }

    .brand-title {
        font-weight: 900;
        color: #1e3a5f;
        line-height: 1.6;
        margin-bottom: 14px;
    }

    .brand-text {
        color: #64748b;
        line-height: 1.9;
        margin-bottom: 22px;
    }

    .feature-list {
        display: grid;
        gap: 12px;
    }

    .feature-item {
        display: flex;
        gap: 12px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid #dbeafe;
        border-radius: 18px;
        padding: 14px;
    }

    .feature-item i {
        width: 36px;
        height: 36px;
        border-radius: 13px;
        background: #e0f2fe;
        color: #0284c7;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .feature-item h6 {
        font-weight: 900;
        color: #243b53;
        margin-bottom: 3px;
    }

    .feature-item p {
        color: #64748b;
        margin-bottom: 0;
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .form-card {
        padding: 32px;
    }

    .form-header {
        text-align: center;
        margin-bottom: 26px;
    }

    .form-icon {
        width: 68px;
        height: 68px;
        border-radius: 24px;
        background: linear-gradient(135deg, #3b82f6, #38bdf8);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.9rem;
        margin-bottom: 15px;
        box-shadow: 0 14px 30px rgba(59, 130, 246, 0.20);
    }

    .form-title {
        font-weight: 900;
        color: #1e3a5f;
        margin-bottom: 8px;
    }

    .form-subtitle {
        color: #64748b;
        margin-bottom: 0;
        line-height: 1.8;
    }

    .field-box {
        background: #f8fbff;
        border: 1px solid #dbeafe;
        border-radius: 20px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .field-label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 900;
        margin-bottom: 10px;
        color: #243b53;
    }

    .field-label i {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        background: #e0f2fe;
        color: #0284c7;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .form-control,
    .form-select {
        border-radius: 16px;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        background: white;
        color: #1f2937;
    }

    .form-control::placeholder {
        color: #94a3b8;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #7dd3fc;
        box-shadow: 0 0 0 0.18rem rgba(14, 165, 233, 0.13);
    }

    .submit-btn {
        border-radius: 999px;
        padding: 13px;
        font-weight: 900;
        background: linear-gradient(135deg, #3b82f6, #38bdf8);
        border: 0;
        box-shadow: 0 14px 30px rgba(59, 130, 246, 0.20);
    }

    .submit-btn:hover {
        background: linear-gradient(135deg, #2563eb, #0ea5e9);
    }

    .login-link {
        color: #2563eb;
        text-decoration: none;
        font-weight: 900;
    }

    .login-link:hover {
        color: #1d4ed8;
    }

    @@media (max-width: 992px) {
        .register-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 576px) {
        .brand-card,
        .form-card {
            padding: 24px;
            border-radius: 24px;
        }
    }
</style>

<div class="container register-page mt-5 mb-5">

    <div class="register-layout">

        <aside class="brand-card">
            <div class="brand-content">

                <div class="brand-icon">
                    <i class="bi bi-shield-check"></i>
                </div>

                <div class="brand-badge">
                    <i class="bi bi-lightning-charge-fill"></i>
                    @Localizer["EmergencySolutionsPlatform"]
                </div>

                <h2 class="brand-title">
                    @Localizer["StartJourney"]
                    <br />
                    <span dir="ltr">EventRescue</span>
                </h2>

                <p class="brand-text">
                    @Localizer["RegisterBrandText"]
                </p>

                <div class="feature-list">

                    <div class="feature-item">
                        <i class="bi bi-calendar-check"></i>
                        <div>
                            <h6>@Localizer["OrganizedRequests"]</h6>
                            <p>@Localizer["OrganizedRequestsText"]</p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <i class="bi bi-geo-alt"></i>
                        <div>
                            <h6>@Localizer["ByCity"]</h6>
                            <p>@Localizer["ByCityText"]</p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <i class="bi bi-tools"></i>
                        <div>
                            <h6>@Localizer["SuitableServices"]</h6>
                            <p>@Localizer["SuitableServicesText"]</p>
                        </div>
                    </div>

                </div>

            </div>
        </aside>

        <main class="form-card">

            <div class="form-header">
                <div class="form-icon">
                    <i class="bi bi-person-plus-fill"></i>
                </div>

                <h3 class="form-title">
                    @Localizer["RegisterNewAccount"]
                </h3>

                <p class="form-subtitle">
                    @Localizer["RegisterSubtitle"]
                </p>
            </div>

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="field-box">
                    <label asp-for="FullName" class="field-label">
                        <i class="bi bi-person"></i>
                        @Localizer["FullName"]
                    </label>

                    <input asp-for="FullName"
                           class="form-control"
                           placeholder="@Localizer["FullNamePlaceholder"]" />

                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="field-box">
                    <label asp-for="Email" class="field-label">
                        <i class="bi bi-envelope"></i>
                        @Localizer["Email"]
                    </label>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="name@example.com" />

                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="field-box">
                            <label asp-for="Password" class="field-label">
                                <i class="bi bi-lock"></i>
                                @Localizer["Password"]
                            </label>

                            <input asp-for="Password"
                                   class="form-control"
                                   placeholder="••••••" />

                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="field-box">
                            <label asp-for="ConfirmPassword" class="field-label">
                                <i class="bi bi-lock-fill"></i>
                                @Localizer["ConfirmPassword"]
                            </label>

                            <input asp-for="ConfirmPassword"
                                   class="form-control"
                                   placeholder="••••••" />

                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="field-box">
                    <label asp-for="RegionId" class="field-label">
                        <i class="bi bi-geo-alt"></i>
                        @Localizer["Region"]
                    </label>

                    <select asp-for="RegionId" class="form-select">
                        <option value="">@Localizer["ChooseCity"]</option>

                     @if (regions != null)
{
    foreach (var region in regions)
    {
        var regionName = region.Name.Trim();

        if (isEnglish && regionTranslations.ContainsKey(regionName))
        {
            regionName = regionTranslations[regionName];
        }

        <option value="@region.Id">@regionName</option>
    }
}
                    </select>

                    <span asp-validation-for="RegionId" class="text-danger"></span>
                </div>

                <div class="field-box">
                    <label asp-for="AccountType" class="field-label">
                        <i class="bi bi-person-badge"></i>
                        @Localizer["AccountType"]
                    </label>

                    <select asp-for="AccountType" class="form-select" id="accountTypeSelect">
                        <option value="@UserType.Client">@Localizer["Client"]</option>
                        <option value="@UserType.Provider">@Localizer["Provider"]</option>
                    </select>

                    <span asp-validation-for="AccountType" class="text-danger"></span>
                </div>

                <div class="field-box" id="categoryBox" style="display:none;">
                    <label asp-for="CategoryId" class="field-label">
                        <i class="bi bi-tools"></i>
                        @Localizer["Category"]
                    </label>

                    <select asp-for="CategoryId" class="form-select">
                        <option value="">@Localizer["ChooseCategory"]</option>

                      @if (categories != null)
{
    foreach (var category in categories)
    {
        var categoryName = category.Name.Trim();

        if (isEnglish && categoryTranslations.ContainsKey(categoryName))
        {
            categoryName = categoryTranslations[categoryName];
        }

        <option value="@category.Id">@categoryName</option>
    }
}
                    </select>

                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 submit-btn">
                    <i class="bi bi-person-plus"></i>
                    @Localizer["CreateAccount"]
                </button>

                <div class="text-center mt-3">
                    <span class="text-muted">@Localizer["HaveAccount"]</span>
                    <a asp-action="Login" class="login-link">@Localizer["Login"]</a>
                </div>
            </form>

        </main>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const accountTypeSelect = document.getElementById("accountTypeSelect");
        const categoryBox = document.getElementById("categoryBox");

        function toggleCategoryBox() {
            if (accountTypeSelect.value === "Provider") {
                categoryBox.style.display = "block";
            } else {
                categoryBox.style.display = "none";
            }
        }

        accountTypeSelect.addEventListener("change", toggleCategoryBox);
        toggleCategoryBox();
    </script>
}