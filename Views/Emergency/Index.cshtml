@model List<EventRescue.Models.EventRequest>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<EventRescue.SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["TodayEmergency"];
    var currentProviderId = ViewBag.CurrentProviderId as string;
    bool isAvailableNow = ViewBag.IsAvailableNow;
}

<div class="container er-page mt-4 mb-5">

    @* ================== الهيرو — بنبرة طوارئ حمراء ================== *@
    <section class="er-hero mb-4">
        <div class="er-hero-content">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="er-badge" style="background: rgba(239, 68, 68, 0.15); border-color: rgba(239, 68, 68, 0.30); color: #fca5a5;">
                        <i class="bi bi-alarm-fill"></i>
                        @Localizer["EmergencyBadge"]
                    </div>
                    <h1 class="er-title">@Localizer["EmergencyTitle"]</h1>
                    <p class="er-subtitle mb-0">
                        @Localizer["EmergencyHeroText"]
                    </p>
                </div>
                <div class="col-lg-4 mt-4 mt-lg-0 text-lg-start text-center">
                    @* زر التوفر للفزعات *@
                    <form asp-controller="Emergency" asp-action="ToggleAvailability" method="post">
                        @Html.AntiForgeryToken()
                        @if (isAvailableNow)
                        {
                            <button type="submit" class="btn btn-success er-btn w-100">
                                <i class="bi bi-lightning-charge-fill"></i>
                                @Localizer["EmergencyAvailableBtn"]
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-outline-light er-btn w-100">
                                <i class="bi bi-moon"></i>
                                @Localizer["EmergencyUnavailableBtn"]
                            </button>
                        }
                    </form>
                </div>
            </div>
        </div>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ================== الوضع هادئ ================== *@
    @if (!Model.Any())
    {
        <div class="er-card er-card-body text-center py-5">
            <span class="er-soft-icon mb-3" style="width: 70px; height: 70px; font-size: 2rem; background: #dcfce7; color: #166534;">
                <i class="bi bi-shield-check"></i>
            </span>
            <h5 class="fw-bold">@Localizer["EmergencyCalmTitle"]</h5>
            <p class="er-muted mb-0">@Localizer["EmergencyCalmText"]</p>
        </div>
    }

    @* ================== بطاقات الفزعات ================== *@
    <div class="row g-4">
        @foreach (var request in Model)
        {
            var myOffer = request.ProviderOffers
                .FirstOrDefault(o => o.ProviderId == currentProviderId);

            var hoursLeft = (int)(request.EventDate - DateTime.Now).TotalHours;

            <div class="col-xl-6">
                <div class="er-card h-100 overflow-hidden" style="border-right: 4px solid #ef4444;">

                    @if (!string.IsNullOrEmpty(request.ImagePath))
                    {
                        <img src="@request.ImagePath" alt="@Localizer["MyRequestsImageAlt"]"
                             style="width: 100%; height: 190px; object-fit: cover;" />
                    }

                    <div class="er-card-body">

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="er-soft-icon">
                                    <i class="@request.Category?.Icon"></i>
                                </span>
                                <strong>@request.Category?.Name</strong>
                            </div>
                            <span class="er-status er-status-canceled">
                                <i class="bi bi-alarm-fill"></i>
                                @Localizer["EmergencyHoursLeft", hoursLeft]
                            </span>
                        </div>

                        <h5 class="fw-bold">@request.Title</h5>
                        <p class="er-muted">@request.Description</p>

                        <div class="d-flex flex-wrap gap-3 small er-muted mb-3">
                            <span><i class="bi bi-geo-alt-fill text-danger"></i> @request.Region?.Name — @request.Address</span>
                            <span><i class="bi bi-calendar-event text-danger"></i> @request.EventDate.ToString("yyyy/MM/dd — hh:mm tt")</span>
                            <span><i class="bi bi-people-fill text-danger"></i> @request.ProviderOffers.Count @Localizer["RadarOffersCount"]</span>
                        </div>

                        @if (myOffer != null)
                        {
                            @* عرضي المقدم + زر سحب العرض (عملية Delete) *@
                            <div class="alert alert-info rounded-4 py-2 mb-2">
                                <i class="bi bi-hourglass-split"></i>
                                @Localizer["RadarYouOffered"] <strong>@myOffer.Price @Localizer["DetailsRiyal"]</strong>
                                — @Localizer["RadarWaitingClient"]
                            </div>
                            <form asp-controller="Providers" asp-action="WithdrawOffer" method="post"
                                  onsubmit="return confirm('@Localizer["RadarConfirmWithdraw"]');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="offerId" value="@myOffer.Id" />
                                <button type="submit" class="btn btn-outline-danger er-btn w-100">
                                    <i class="bi bi-trash3"></i> @Localizer["RadarWithdrawOffer"]
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="Providers" asp-action="SendOffer" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventRequestId" value="@request.Id" />
                                <div class="input-group">
                                    <span class="input-group-text">@Localizer["DetailsRiyal"]</span>
                                    <input type="number" name="price" class="form-control"
                                           placeholder="@Localizer["EmergencyPricePlaceholder"]" min="1" max="100000" step="0.5" required />
                                    <button type="submit" class="btn btn-danger er-btn">
                                        <i class="bi bi-lightning-charge-fill"></i> @Localizer["EmergencyGoBtn"]
                                    </button>
                                </div>
                            </form>
                        }

                    </div>
                </div>
            </div>
        }
    </div>

</div>
