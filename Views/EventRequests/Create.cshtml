@model EventRescue.ViewModels.CreateEventRequestViewModel
@using EventRescue.Models
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<EventRescue.SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["CreateRequestPageTitle"];

    var categories = ViewBag.Categories as List<Category>;

    var isEnglish = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en");

    var categoryTranslations = new Dictionary<string, string>
    {
        { "قهوجي أو قهوجية", "Coffee Server" },
        { "مقدمات ضيافة", "Hospitality Hostesses" },
        { "عاملة تنظيف", "Cleaning Worker" },
        { "فني إصلاح أثاث", "Furniture Repair Technician" },
        { "منسق ورد", "Flower Coordinator" },
        { "مصور مناسبات", "Event Photographer" },
        { "شيف منزلي", "Home Chef" },
        { "سائق توصيل", "Delivery Driver" },
        { "كراسي وطاولات", "Tables and Chairs" },
        { "كنب", "Sofas" },
        { "خيام", "Tents" },
        { "سخانات ومبردات", "Heaters and Coolers" }
    };
}

<style>
    body {
        background:
            radial-gradient(circle at top right, rgba(147, 197, 253, 0.25), transparent 28%),
            radial-gradient(circle at bottom left, rgba(187, 247, 208, 0.22), transparent 30%),
            #f4f7fb;
    }

   .create-page {
    direction: rtl;
    color: #1f2937;
        }
    html[dir="ltr"] .create-page {
    direction: ltr;
        }
    .soft-hero {
        background:
            linear-gradient(135deg, #ffffff 0%, #eaf3ff 55%, #eefbf3 100%);
        border: 1px solid #dbe7f3;
        border-radius: 32px;
        padding: 36px;
        box-shadow: 0 18px 45px rgba(71, 85, 105, 0.10);
        margin-bottom: 26px;
        position: relative;
        overflow: hidden;
    }

    .soft-hero::after {
        content: "";
        position: absolute;
        width: 190px;
        height: 190px;
        border-radius: 50%;
        background: rgba(147, 197, 253, 0.26);
        left: -65px;
        bottom: -75px;
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #e0f2fe;
        color: #0369a1;
        border: 1px solid #bae6fd;
        border-radius: 999px;
        padding: 8px 15px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .hero-title {
        font-weight: 900;
        color: #1e3a5f;
        margin-bottom: 10px;
    }

    .hero-text {
        color: #64748b;
        line-height: 1.9;
        margin-bottom: 0;
        max-width: 720px;
    }

    .top-link {
        border-radius: 999px;
        font-weight: 800;
        padding: 10px 22px;
        background: #ffffff;
        border: 1px solid #cbd5e1;
        color: #334155;
    }

    .top-link:hover {
        background: #eff6ff;
        border-color: #93c5fd;
        color: #1d4ed8;
    }

    .create-layout {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 24px;
        align-items: start;
    }

    .form-card,
    .guide-card {
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid #dbe7f3;
        border-radius: 30px;
        box-shadow: 0 18px 45px rgba(71, 85, 105, 0.09);
        backdrop-filter: blur(10px);
    }

    .form-card {
        padding: 30px;
    }

    .guide-card {
        padding: 26px;
        position: sticky;
        top: 24px;
    }

    .section-title {
        font-weight: 900;
        color: #1e3a5f;
        margin-bottom: 8px;
    }

    .section-desc {
        color: #64748b;
        line-height: 1.8;
        margin-bottom: 24px;
    }

    .field-box {
        background: #f8fbff;
        border: 1px solid #dbeafe;
        border-radius: 22px;
        padding: 18px;
        margin-bottom: 18px;
    }

    .field-label {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 900;
        margin-bottom: 12px;
        color: #243b53;
    }

    .field-icon {
        width: 44px;
        height: 44px;
        border-radius: 15px;
        background: #e0f2fe;
        color: #0284c7;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.15rem;
    }

    .form-control,
    .form-select {
        border-radius: 16px;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        background: #ffffff;
        color: #1f2937;
    }

    .form-control::placeholder {
        color: #94a3b8;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #7dd3fc;
        box-shadow: 0 0 0 0.18rem rgba(14, 165, 233, 0.13);
    }

    .form-text {
        color: #64748b;
    }

    .submit-btn {
        border-radius: 999px;
        padding: 13px;
        font-weight: 900;
        background: linear-gradient(135deg, #3b82f6, #38bdf8);
        border: 0;
        box-shadow: 0 14px 30px rgba(59, 130, 246, 0.20);
    }

    .submit-btn:hover {
        background: linear-gradient(135deg, #2563eb, #0ea5e9);
    }

    .secondary-link {
        color: #2563eb;
        text-decoration: none;
        font-weight: 800;
    }

    .secondary-link:hover {
        color: #1d4ed8;
    }

    .guide-header {
        display: flex;
        align-items: center;
        gap: 13px;
        margin-bottom: 22px;
    }

    .guide-icon {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        background: linear-gradient(135deg, #93c5fd, #bbf7d0);
        color: #1e3a5f;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .guide-title {
        font-weight: 900;
        color: #1e3a5f;
        margin-bottom: 4px;
    }

    .guide-text {
        color: #64748b;
        margin-bottom: 0;
        font-size: 0.95rem;
    }

    .hint-list {
        display: grid;
        gap: 12px;
    }

    .hint-item {
        display: flex;
        gap: 12px;
        background: #f8fbff;
        border: 1px solid #dbeafe;
        border-radius: 18px;
        padding: 15px;
    }

    .hint-number {
        width: 34px;
        height: 34px;
        border-radius: 12px;
        background: #e0f2fe;
        color: #0284c7;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        flex-shrink: 0;
    }

    .hint-title {
        font-weight: 900;
        color: #243b53;
        margin-bottom: 4px;
    }

    .hint-desc {
        color: #64748b;
        margin-bottom: 0;
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .note-box {
        margin-top: 18px;
        background: #eefbf3;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 16px;
    }

    .note-title {
        color: #15803d;
        font-weight: 900;
        margin-bottom: 6px;
    }

    .note-text {
        color: #475569;
        margin-bottom: 0;
        line-height: 1.7;
        font-size: 0.92rem;
    }

    @@media (max-width: 992px) {
        .create-layout {
            grid-template-columns: 1fr;
        }

        .guide-card {
            position: static;
        }
    }

    @@media (max-width: 576px) {
        .soft-hero,
        .form-card,
        .guide-card {
            padding: 24px;
            border-radius: 24px;
        }
    }
</style>

<div class="container create-page mt-5 mb-5">

    <section class="soft-hero">
        <div class="hero-content">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="hero-badge">
                        <i class="bi bi-calendar-plus-fill"></i>
                        @Localizer["NewServiceRequest"]
                    </div>

                    <h1 class="hero-title">
                        @Localizer["SubmitRequestClearly"]
                        
                    </h1>

                    <p class="hero-text">
                  @Localizer["CreateRequestHeroText"]
                    </p>
                </div>

                <div class="col-lg-4 text-lg-start text-center mt-4 mt-lg-0">
                    <a asp-controller="EventRequests" asp-action="MyRequests" class="btn top-link">
                        <i class="bi bi-list-check"></i>
                        @Localizer["ViewMyRequests"] 
                    </a>
                </div>
            </div>
        </div>
    </section>

    <div class="create-layout">

        <main class="form-card">

            <h4 class="section-title">
               @Localizer["RequestInformation"]
            </h4>

            <p class="section-desc">
                @Localizer["RequestInformationText"]
            </p>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="field-box">
                    <label asp-for="CategoryId" class="field-label">
                        <span class="field-icon">
                            <i class="bi bi-tools"></i>
                        </span>
                       @Localizer["ServiceType"]
                    </label>

                    <select asp-for="CategoryId" class="form-select">
                        <option value="0">@Localizer["ChooseServiceType"]</option>

                       @if (categories != null)
                     {
                  foreach (var category in categories)
                 {
                   var categoryName = category.Name.Trim();

                  if (isEnglish && categoryTranslations.ContainsKey(categoryName))
                 {
              categoryName = categoryTranslations[categoryName];
                }

        <option value="@category.Id">@categoryName</option>
    }
}
                    </select>

                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="field-box">
                    <label asp-for="Title" class="field-label">
                        <span class="field-icon">
                            <i class="bi bi-pencil-square"></i>
                        </span>
                        @Localizer["RequestTitle"]
                    </label>

                    <input asp-for="Title"
                           class="form-control"
                          placeholder="@Localizer["RequestTitlePlaceholder"]" />

                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="field-box">
                    <label asp-for="Description" class="field-label">
                        <span class="field-icon">
                            <i class="bi bi-card-text"></i>
                        </span>
                       @Localizer["ProblemDescription"]
                    </label>

                    <textarea asp-for="Description"
                              class="form-control"
                              rows="5"
                              placeholder="@Localizer["ProblemDescriptionPlaceholder"]"></textarea>

                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="field-box">
                            <label asp-for="EventDate" class="field-label">
                                <span class="field-icon">
                                    <i class="bi bi-calendar-event"></i>
                                </span>
                                @Localizer["EventDate"] 
                            </label>

                            @* datetime-local: تاريخ + وقت، حتى يتصنف طلب الفزعة (أقل من 24 ساعة) بدقة *@
                            <input asp-for="EventDate"
                                   type="datetime-local"
                                   class="form-control"
                                   min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />

                            <span asp-validation-for="EventDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="field-box">
                            <label asp-for="Address" class="field-label">
                                <span class="field-icon">
                                    <i class="bi bi-geo-alt"></i>
                                </span>
                                @Localizer["AddressNeighborhood"]
                            </label>

                            <input asp-for="Address"
                                   class="form-control"
                                  placeholder="@Localizer["AddressPlaceholder"]" />

                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="field-box">
                    <label asp-for="ImageFile" class="field-label">
                        <span class="field-icon">
                            <i class="bi bi-image"></i>
                        </span>
                        @Localizer["ProblemImage"] 
                    </label>

                    <input asp-for="ImageFile"
                           type="file"
                           class="form-control"
                           accept="image/*" />

                    <div class="form-text mt-2">
                       @Localizer["ImageHelpText"]
                    </div>

                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 submit-btn">
                    <i class="bi bi-send-fill"></i>
                    @Localizer["SendRequest"] 
                </button>

                <div class="text-center mt-3">
                    <a asp-controller="EventRequests" asp-action="MyRequests" class="secondary-link">
                         @Localizer["ViewMyRequests"]
                    </a>
                </div>
            </form>

        </main>

        <aside class="guide-card">

            <div class="guide-header">
                <span class="guide-icon">
                    <i class="bi bi-check2-square"></i>
                </span>

                <div>
                    <h4 class="guide-title">
                        @Localizer["BeforeSendRequest"]  
                    </h4>

                    <p class="guide-text">
                       @Localizer["CompleteInfoCheck"]
                    </p>
                </div>
            </div>

            <div class="hint-list">

                <div class="hint-item">
                    <div class="hint-number">1</div>
                    <div>
                        <h6 class="hint-title">@Localizer["ChooseServiceHintTitle"] </h6>
                        <p class="hint-desc">
                           @Localizer["ChooseServiceHintText"]
                        </p>
                    </div>
                </div>

                <div class="hint-item">
                    <div class="hint-number">2</div>
                    <div>
                        <h6 class="hint-title">@Localizer["ClearDescriptionHintTitle"]</h6>
                        <p class="hint-desc">
                           @Localizer["ClearDescriptionHintText"]
                        </p>
                    </div>
                </div>

                <div class="hint-item">
                    <div class="hint-number">3</div>
                    <div>
                        <h6 class="hint-title">@Localizer["AttachImageHintTitle"] </h6>
                        <p class="hint-desc">
                           @Localizer["AttachImageHintText"]
                        </p>
                    </div>
                </div>

            </div>

            <div class="note-box">
                <div class="note-title">
                    <i class="bi bi-info-circle"></i>
                    @Localizer["Note"]
                </div>

                <p class="note-text">
                   @Localizer["AutoCityNote"]
                </p>
            </div>

        </aside>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}